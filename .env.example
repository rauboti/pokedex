# Copy to `.env` for local development (`.env` is gitignored). Defaults are set in
# docker-compose.yml, so an empty .env still boots the stack; override as needed.
#
# Ports (pokedex uses the 3050/5050/5437 band — the constitution default, clear of hive
# 3000/5000/5432, taskmaster 3010/5010/5433, pulse 3020/5020/5434, avec 3030/5030/5435
# and tome's claimed 3040/5040/5436):
#   Dev:    web `yarn dev` on 5173, proxying /api to the api on 5050 (run the api
#           via `docker compose up pokedex-db pokedex-api`). One web dev server at a time.
#   Docker: web 3050, api 5050, db 5437 (the api listens on 8080 inside its container).

# ---- Database (Postgres container + the api datasource) ----
POSTGRES_DB=pokedex
POSTGRES_USER=pokedex
POSTGRES_PASSWORD=pokedex_local_dev
# Host port for the db (5437 to avoid clashing with hive 5432 / taskmaster 5433 /
# pulse 5434 / avec 5435 / tome 5436).
POSTGRES_PORT=5437

# ---- API ----
# Origins allowed to call the api. Comma-separated. The dev web (5173) calls the
# api cross-origin; the Docker web (3050) is same-origin via nginx, so CORS isn't
# exercised there, but it's listed for completeness.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3050

# ---- Hive (identity) — consumer integration (research D1) ----
# The api validates Hive-issued JWTs (JWKS) and runs the OAuth login exchange. Two bases:
# EXTERNAL is how the *browser* reaches Hive (authorize redirect) and the expected token `iss`;
# INTERNAL is how the *api container* reaches Hive (token exchange + JWKS). The endpoint paths
# (/oauth2/authorize, /oauth2/token, /.well-known/jwks.json) are derived in code.
# Standalone they can be equal; in the shared Docker stack INTERNAL is Hive's service name
# (e.g. http://hive-api:8080) while EXTERNAL stays the browser-facing localhost URL.
HIVE_EXTERNAL_URL=http://localhost:5000
HIVE_INTERNAL_URL=http://localhost:5000
HIVE_CLIENT_ID=pokedex
# Client secret issued by Hive when Pokedex is registered (T006). Leave blank until then;
# the compose default (pokedex-local-dev) matches the dev seed for local login.
HIVE_CLIENT_SECRET=

# The public web origin. The BFF redirects the browser here after login AND derives its OAuth
# redirect URI from it as {WEB_BASE_URL}/auth/callback (register THAT redirect in Hive). The
# browser reaches the callback via the web origin — nginx (Docker) / the Vite proxy (dev) forward
# /auth to the api. For the Docker stack this is the nginx origin (3050).
WEB_BASE_URL=http://localhost:3050

# ---- Game data (catalog sync, research D5) ----
# Base URL the api's sync module fetches the species/move catalog from (community
# Game Master source). Point it at a dead host or a stub to exercise the
# failure-mode paths (sync fails, catalog unchanged).
GAMEDATA_BASE_URL=https://pokemon-go-api.github.io/pokemon-go-api

# ---- Frontend (dev) ----
# The api origin the SPA calls in `yarn dev` (the api's published port, 5050). In
# the container, nginx proxies /api instead, so this is only used for local dev.
VITE_API_ORIGIN=http://localhost:5050

# ---- Build ----
# GitHub Packages token (read:packages) for the private @rauboti/ui scope. Needed
# only to build the `web` image (docker compose up --build) — passed as a BuildKit
# secret, never baked into a layer. Same token as web/.yarnrc.yml. Leave blank to
# skip building the web image.
RAUBOTI_PACKAGE_TOKEN=
